{
  "name": "@devspace/desktop",
  "version": "0.1.1",
  "private": true,
  "description": "Devspace desktop app with embedded terminal, browser, and editor panes",
  "homepage": "https://github.com/AmrAbuElyazid/devspace",
  "bugs": {
    "url": "https://github.com/AmrAbuElyazid/devspace/issues"
  },
  "author": "Amr Mohamed",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmrAbuElyazid/devspace.git",
    "directory": "apps/desktop"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "bash ../../scripts/ensure-ghostty-native.sh && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-vite postinstall 2>/dev/null; true",
    "rebuild-native": "bun run --cwd ../../packages/ghostty-electron rebuild-native",
    "dist": "bash ./build/dist-mac-release.sh",
    "dist:dir": "bun run build && bun run rebuild-native && bunx electron-builder --mac --arm64 --dir --publish never",
    "test:e2e:packaged": "bunx playwright test --config e2e/playwright.config.ts e2e/packaged-smoke.spec.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bun run rebuild-native && bun run build && bunx playwright test --config e2e/playwright.config.ts",
    "test:e2e:dev": "bun run rebuild-native && bunx playwright test --config e2e/playwright.config.ts",
    "test:e2e:hidden-retention": "bun run rebuild-native && bun run build && bunx playwright test --config e2e/playwright.config.ts e2e/hidden-terminal-retention.spec.ts",
    "test:e2e:stress": "bun run rebuild-native && bun run build && bunx playwright test --config e2e/playwright.config.ts e2e/mixed-workspace-stress.spec.ts",
    "knip": "knip"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@devspace/note-editor": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@steipete/sweet-cookie": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.6.2",
    "ghostty-electron": "workspace:*",
    "lucide-react": "^1.11.0",
    "nanoid": "^5.1.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "catalog:",
    "allotment": "^1.20.5",
    "electron": "catalog:",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.devspace.app",
    "productName": "Devspace",
    "artifactName": "Devspace-${version}-${arch}.${ext}",
    "icon": "build/icon.icns",
    "asar": true,
    "asarUnpack": [
      "../../packages/ghostty-electron/native/build/Release/*.node"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "notarize": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AmrAbuElyazid",
        "repo": "devspace",
        "releaseType": "release"
      }
    ],
    "files": [
      "out/**/*",
      "../../packages/ghostty-electron/native/build/Release/ghostty_bridge.node"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../packages/ghostty-electron/deps/libghostty/share/ghostty",
        "to": "ghostty",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../packages/ghostty-electron/deps/libghostty/share/devspace-shell-integration",
        "to": "devspace-shell-integration",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../packages/ghostty-electron/deps/libghostty/share/terminfo",
        "to": "terminfo",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
