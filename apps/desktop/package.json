{
  "name": "@devspace/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-vite postinstall 2>/dev/null; true",
    "rebuild-native": "cd ../../packages/ghostty-electron/native && npx node-gyp rebuild --target=$(node -e \"console.log(require('electron/package.json').version)\") --arch=$(node -p \"process.arch\") --dist-url=https://electronjs.org/headers",
    "dist": "bun run build && bun run rebuild-native && bunx electron-builder --mac --arm64 --dir",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:e2e": "bun run build && bunx playwright test --config e2e/playwright.config.ts",
    "test:e2e:dev": "bunx playwright test --config e2e/playwright.config.ts",
    "knip": "knip"
  },
  "dependencies": {
    "@ariakit/react": "^0.4.24",
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@platejs/ai": "^52.3.18",
    "@platejs/autoformat": "^52.3.10",
    "@platejs/basic-nodes": "^52.3.10",
    "@platejs/callout": "^52.3.10",
    "@platejs/code-block": "^52.3.16",
    "@platejs/combobox": "^52.3.10",
    "@platejs/floating": "^52.3.10",
    "@platejs/indent": "^52.3.10",
    "@platejs/link": "^52.3.17",
    "@platejs/list": "^52.3.10",
    "@platejs/markdown": "^52.3.19",
    "@platejs/selection": "^52.3.10",
    "@platejs/slash-command": "^52.3.10",
    "@platejs/suggestion": "^52.3.10",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-toolbar": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@steipete/sweet-cookie": "^0.2.0",
    "@udecode/cn": "^52.3.4",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "ghostty-electron": "workspace:*",
    "lowlight": "^3.3.0",
    "nanoid": "^5.1.7",
    "platejs": "^52.3.16",
    "radix-ui": "^1.4.3",
    "remark-gfm": "^4.0.1",
    "remark-stringify": "^11.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "allotment": "^1.20.5",
    "electron": "catalog:",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "knip": "^6.0.6",
    "lucide-react": "^1.7.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.devspace.app",
    "productName": "Devspace",
    "asar": true,
    "asarUnpack": [
      "../../packages/ghostty-electron/native/build/Release/*.node"
    ],
    "mac": {
      "target": "dir",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "../../packages/ghostty-electron/native/build/Release/ghostty_bridge.node"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../packages/ghostty-electron/deps/libghostty/share/ghostty",
        "to": "ghostty",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../packages/ghostty-electron/deps/libghostty/share/devspace-shell-integration",
        "to": "devspace-shell-integration",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../packages/ghostty-electron/deps/libghostty/share/terminfo",
        "to": "terminfo",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
