#!/bin/bash
#
# devspace — CLI for the Devspace desktop app.
#
# Usage:
#   devspace code [<folder>]   Open a folder in the built-in VS Code editor
#   devspace --help            Show this help message
#
# If Devspace is not running, the app is launched automatically.

set -euo pipefail

VERSION="0.1.0"

# ── Help / version ──────────────────────────────────────────────────────────

show_help() {
  cat <<'EOF'
Usage: devspace <command> [options]

Commands:
  code [<folder>]   Open a folder in the built-in VS Code editor.
                    Defaults to the current directory if no folder is given.

Options:
  --help, -h        Show this help message
  --version, -v     Show version

Examples:
  devspace code            # open VS Code with the current directory
  devspace code .          # same as above
  devspace code ~/project  # open VS Code with ~/project
EOF
}

# ── Argument parsing ────────────────────────────────────────────────────────

if [ $# -eq 0 ]; then
  show_help
  exit 0
fi

case "$1" in
  --help|-h)
    show_help
    exit 0
    ;;
  --version|-v)
    echo "devspace $VERSION"
    exit 0
    ;;
  code)
    shift  # consume the "code" subcommand
    ;;
  *)
    echo "Error: unknown command '$1'" >&2
    echo "Run 'devspace --help' for usage." >&2
    exit 1
    ;;
esac

# ── Resolve folder ──────────────────────────────────────────────────────────

if [ $# -eq 0 ]; then
  FOLDER="$(pwd)"
else
  if [ ! -d "$1" ]; then
    echo "Error: '$1' is not a directory" >&2
    exit 1
  fi
  FOLDER="$(cd "$1" && pwd)"
fi

# Percent-encode the folder path for use as a URL query parameter.
# Uses perl (ships with macOS) for proper RFC 3986 encoding.
ENCODED=$(printf '%s' "$FOLDER" | perl -pe 's/([^A-Za-z0-9\-._~\/])/sprintf("%%%02X", ord($1))/ge')

# ── Communication with Devspace app ────────────────────────────────────────

# Auth token directory (Electron userData on macOS)
TOKEN_DIR="$HOME/Library/Application Support/devspace/cli"

# Try a port: read the auth token, send the request with the token header.
try_port() {
  local port="$1"
  local token_file="$TOKEN_DIR/token.$port"
  [ -f "$token_file" ] || return 1
  local token
  token=$(<"$token_file")
  curl -sf -H "X-Devspace-Token: $token" \
    "http://127.0.0.1:$port/open-editor?path=$ENCODED" >/dev/null 2>&1
}

# Try production port (21549), then dev port (21649)
try_port 21549 && exit 0
try_port 21649 && exit 0

# ── Auto-launch Devspace ───────────────────────────────────────────────────

echo "Devspace is not running. Launching..." >&2

# Try to launch via macOS `open` command. Check common locations.
LAUNCHED=false
if [ -d "/Applications/Devspace.app" ]; then
  open -a "Devspace" && LAUNCHED=true
elif [ -d "$HOME/Applications/Devspace.app" ]; then
  open "$HOME/Applications/Devspace.app" && LAUNCHED=true
else
  # Fallback: try `open -a` which searches all app directories
  open -a "Devspace" 2>/dev/null && LAUNCHED=true
fi

if [ "$LAUNCHED" = false ]; then
  echo "Error: Could not find Devspace.app. Is it installed?" >&2
  exit 1
fi

# Poll until the CLI HTTP server is ready (up to 15 seconds).
TIMEOUT=30  # iterations (× 500ms = 15s)
i=0
while [ $i -lt $TIMEOUT ]; do
  if try_port 21549; then
    exit 0
  fi
  if try_port 21649; then
    exit 0
  fi
  sleep 0.5
  i=$((i + 1))
done

echo "Error: Devspace launched but the CLI server did not start in time." >&2
echo "Try running the command again in a moment." >&2
exit 1
