{
  "name": "ghostty-electron",
  "version": "0.1.0",
  "description": "Ghostty terminal emulator bridge for Electron apps",
  "keywords": [
    "electron",
    "ghostty",
    "native",
    "terminal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/devspace",
    "directory": "packages/ghostty-electron"
  },
  "files": [
    "src",
    "native",
    "deps",
    "share"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build-libghostty": "bash ./scripts/build-libghostty.sh",
    "bundle-libghostty": "bash ./scripts/bundle-libghostty.sh",
    "provision-libghostty": "bash ./scripts/provision-libghostty.sh",
    "rebuild-native": "bash ./scripts/rebuild-native.sh",
    "refresh-libghostty-checksums": "bash ./scripts/write-libghostty-checksums.sh",
    "knip": "knip",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify-libghostty": "bash ./scripts/verify-libghostty.sh"
  },
  "dependencies": {
    "node-addon-api": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "catalog:",
    "knip": "catalog:",
    "node-gyp": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "electron": ">=30"
  }
}
