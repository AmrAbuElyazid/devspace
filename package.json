{
  "name": "devspace",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-vite postinstall 2>/dev/null; true",
    "rebuild-native": "cd native && npx node-gyp rebuild --target=$(node -e \"console.log(require('electron/package.json').version)\") --arch=arm64 --dist-url=https://electronjs.org/headers",
    "dist": "bun run build && bun run rebuild-native && bunx electron-builder --mac --arm64 --dir",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:e2e": "bun run build && bunx playwright test --config e2e/playwright.config.ts",
    "test:e2e:dev": "bunx playwright test --config e2e/playwright.config.ts",
    "knip": "knip"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@steipete/sweet-cookie": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "nanoid": "^5.1.7",
    "node-addon-api": "^8.7.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "allotment": "^1.20.5",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "knip": "^6.0.6",
    "lucide-react": "^1.7.0",
    "node-gyp": "^12.2.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.devspace.app",
    "productName": "Devspace",
    "asar": true,
    "asarUnpack": [
      "native/build/Release/*.node"
    ],
    "mac": {
      "target": "dir",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "native/build/Release/ghostty_bridge.node"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
