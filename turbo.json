{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "dist": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["release/**"],
      "passThroughEnv": [
        "APPLE_API_KEY",
        "APPLE_API_KEY_ID",
        "APPLE_API_ISSUER",
        "APPLE_KEYCHAIN",
        "APPLE_KEYCHAIN_PROFILE",
        "CSC_LINK",
        "CSC_KEY_PASSWORD"
      ]
    },
    "knip": {
      "cache": false,
      "outputs": []
    }
  }
}
