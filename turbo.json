{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "DEVSPACE_DISABLE_AUTO_UPDATE",
        "DEVSPACE_ENABLE_AUTO_UPDATE_IN_DEV",
        "DEVSPACE_MOCK_UPDATE_PERCENT",
        "DEVSPACE_MOCK_UPDATE_STATE",
        "DEVSPACE_MOCK_UPDATE_VERSION",
        "DEVSPACE_UPDATE_FEED_URL"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "dist": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["release/**"],
      "passThroughEnv": [
        "APPLE_API_KEY",
        "APPLE_API_KEY_ID",
        "APPLE_API_ISSUER",
        "APPLE_KEYCHAIN",
        "APPLE_KEYCHAIN_PROFILE",
        "CSC_LINK",
        "CSC_KEY_PASSWORD",
        "GH_TOKEN"
      ]
    },
    "knip": {
      "cache": false,
      "outputs": []
    }
  }
}
